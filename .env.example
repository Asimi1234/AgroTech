# Copy to `.env` and adjust for your environment.

# Base URL for the Phase 2 backend API (used only by the HttpApi fallback).
VITE_API_BASE_URL=http://localhost:4000/api

# Supabase connection. When VITE_USE_MOCK_API=false and both are set, the app
# talks to Supabase directly (SupabaseApi). VITE_SUPABASE_URL is the bare
# project URL — the REST "/rest/v1/" suffix is stripped automatically if present.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Toggle the data source. "true" uses the in-memory mock layer (Phase 1).
# Set to "false" to use Supabase (falls back to HttpApi if Supabase is unset).
VITE_USE_MOCK_API=false

# Artificial latency (ms) applied to mock responses to simulate network delay.
VITE_MOCK_LATENCY_MS=600
